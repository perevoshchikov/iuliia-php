{
    "name": "anper/iuliia",
    "type": "library",
    "description": "Transliterate Cyrillic → Latin in every possible way.",
    "keywords": [
        "iuliia",
        "cyrillic",
        "latin",
        "transliterate",
        "translit",
        "translate"
    ],
    "homepage": "https://github.com/perevoshchikov/iuliia-php",
    "license": "MIT",
    "authors": [
        {
            "name": "Anton Perevoshchikov",
            "email": "anper3.5@gmail.com"
        }
    ],
    "require": {
        "php": ">=7.3",
        "ext-mbstring": "*"
    },
    "require-dev": {
        "ext-json": "*",
        "phpstan/phpstan": ">=1.4",
        "phpunit/phpunit": ">=7.0",
        "squizlabs/php_codesniffer": ">=3.6"
    },
    "autoload": {
        "psr-4": {
            "Anper\\Iuliia\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Anper\\Iuliia\\Tests\\": "tests"
        }
    },
    "scripts": {
        "test": [
            "@php -r \"copy(version_compare(PHP_VERSION, '8.1.0') >= 0 ? 'phpunit.xml.dist' : 'phpunit.legacy.xml.dist', 'phpunit.xml');\"",
            "phpunit --no-coverage"
        ],
        "build": "@php ./bin/build.php",
        "stan": "phpstan analyse",
        "check-style": "phpcs",
        "fix-style": "phpcbf"
    },
    "config": {
        "sort-packages": true
    }
}
